# Application environment: dev, staging, production
NODE_ENV=dev

# Public URL for callbacks, CORS and absolute links
APP_URL=http://localhost:8000

# Managed Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# LLM provider key used by the backend service
LLM_API_KEY=replace-me

# Secret used to sign sessions/tokens. Generate a unique value per environment.
AUTH_SECRET=replace-me-with-a-long-random-secret
