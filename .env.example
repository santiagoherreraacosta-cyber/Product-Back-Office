# Server-only secrets. Never expose these with VITE_, NEXT_PUBLIC_, or client-side bundles.
OPENAI_API_KEY=sk-REPLACE_ME

# Comma-separated origin allowlist for browser clients.
ALLOWED_ORIGINS=http://localhost:8000,https://backoffice.example.com

# Authorization map: team:cycle|cycle,team2:cycle3
TEAM_ACCESS=demo-team:demo-cycle

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
PORT=8000
