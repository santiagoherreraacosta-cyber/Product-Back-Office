# Copy to .env and fill in values
PORT=8000
AUTH_SECRET=change-me-to-a-random-32-byte-hex-string
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,https://PLACEHOLDER_VERCEL_URL.vercel.app
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
DATABASE_URL=postgresql://user:password@localhost:5432/dropi
# Demo user credentials (loaded at startup; if unset, login is disabled for that role)
ADMIN_EMAIL=admin@dropi.co
ADMIN_PASSWORD=change-me-strong-password
PM_EMAIL=pm@dropi.co
PM_PASSWORD=change-me-strong-password
